DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY='local-dev-only-not-the-prod-key'
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:8000
SECURE_SSL_REDIRECT=False

# Host-facing values, for running manage.py natively.
# Under Docker these are overridden by docker-compose.dev.yml's
# `environment:` block (db:5432 / redis:6379), so both paths work.
DATABASE_URL=postgres://aurora_user:admin@localhost:5433/aurora_db
POSTGRES_DB=aurora_db
POSTGRES_USER=aurora_user
POSTGRES_PASSWORD=admin

REDIS_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000