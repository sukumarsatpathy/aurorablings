# =============================
# Aurora Blings Environment
# =============================

# Django core
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=aurorablings.com,www.aurorablings.com,api.aurorablings.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://aurorablings.com,https://www.aurorablings.com,https://api.aurorablings.com
DJANGO_SETTINGS_MODULE=config.settings.prod
BACKEND_URL=https://api.aurorablings.com

# Static / media / logs (shared paths on server)
STATIC_URL=/static/
MEDIA_URL=/media/
DJANGO_STATIC_ROOT=/srv/aurorablings/shared/static
DJANGO_MEDIA_ROOT=/srv/aurorablings/shared/media
DJANGO_LOG_DIR=/srv/aurorablings/shared/logs

# Security and CORS
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://aurorablings.com,https://www.aurorablings.com,https://admin.aurorablings.com

# Database
DATABASE_URL=postgres://postgres:admin@127.0.0.1:5432/aurora_db

# Redis / Celery
REDIS_URL=redis://127.0.0.1:6379/1
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

# Gunicorn runtime
GUNICORN_BIND=unix:/srv/aurorablings/shared/run/gunicorn.sock
GUNICORN_TIMEOUT=60
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=100
GUNICORN_LOG_LEVEL=info

# SMTP
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=example@gmail.com
EMAIL_HOST_PASSWORD=app-password
DEFAULT_FROM_EMAIL=Aurora Blings <noreply@aurorablings.com>
ADMINS_EMAIL=ops@aurorablings.com

# Cashfree
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_ENV=sandbox

# Cloudflare Turnstile
TURNSTILE_ENABLED=False
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Upload limits
IMAGE_UPLOAD_MAX_BYTES=5242880
IMAGE_UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp